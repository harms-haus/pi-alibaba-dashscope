{
  "name": "pi-alibaba-dashscope",
  "version": "1.0.0",
  "description": "Alibaba Cloud (DashScope) provider extension for pi-agent",
  "type": "module",
  "main": "src/index.ts",
  "files": [
    "src/**/*.ts",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "alibaba-cloud",
    "dashscope",
    "qwen"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/harms-haus/pi-alibaba-dashscope"
  },
  "scripts": {
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@eslint/js": "^9.0.0",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.0.0",
    "typescript-eslint": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  }
}
